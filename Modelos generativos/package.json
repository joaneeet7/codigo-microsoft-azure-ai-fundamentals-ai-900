{
  "name": "modelos-generativos",
  "version": "0.1.0",
  "private": true,
  "description": "Demo de salidas visuales con modelos generativos.",
  "scripts": {
    "dev:backend": "cd backend && py -m uvicorn app.main:app --reload --host 0.0.0.0 --port 3030",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build": "npm run build --prefix frontend",
    "typecheck": "npm run typecheck --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
