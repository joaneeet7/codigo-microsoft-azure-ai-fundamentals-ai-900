# Credenciales del recurso de Azure AI Foundry / Content Understanding
AZURE_CONTENT_UNDERSTANDING_ENDPOINT=https://TU-RECURSO.services.ai.azure.com
AZURE_CONTENT_UNDERSTANDING_KEY=TU-API-KEY
AZURE_CONTENT_UNDERSTANDING_API_VERSION=2025-11-01

# Opcional: analyzer personalizado para documentos/formularios.
# Si lo dejas vacio, los documentos se procesan con OCR Read (prebuilt-read).
AZURE_CONTENT_UNDERSTANDING_ANALYZER_ID=

# Opcional: sobreescribe el analyzer por modalidad.
# Valores por defecto si se dejan vacios (API 2025-11-01):
#   document -> prebuilt-read         (OCR Read)
#   image    -> prebuilt-read         (OCR Read)
#   audio    -> prebuilt-audioSearch  (transcripcion + resumen)
#   video    -> prebuilt-videoSearch  (transcripcion + segmentos)
AZURE_CU_DOCUMENT_ANALYZER_ID=
AZURE_CU_IMAGE_ANALYZER_ID=
AZURE_CU_AUDIO_ANALYZER_ID=
AZURE_CU_VIDEO_ANALYZER_ID=
